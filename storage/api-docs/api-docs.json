            "post": {
                "tags": [
                    "Meter Listrik"
                ],
                "summary": "Tambah meter listrik",
                "operationId": "4e4124a485a0cc9279fbb2642b02d330",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "pelanggan_id",
                                    "nomor_meter",
                                    "daya"
                                ],
                                "properties": {
                                    "pelanggan_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "nomor_meter": {
                                        "type": "string",
                                        "example": "MTR001"
                                    },
                                    "daya": {
                                        "type": "string",
                                        "example": "1300 VA"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Berhasil ditambahkan"
                    }
                }
            }
